# ═══════════════════════════════════════════════════════════
# TouristGuide Backend — Environment Variables
# ═══════════════════════════════════════════════════════════

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/touristguide?retryWrites=true&w=majority

# JWT Secret — use a long random string (openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,exp://192.168.1.100:8081

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=10
