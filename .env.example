# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<USER>:<PASSWORD>@cluster1.eujlfyx.mongodb.net/touristguide?retryWrites=true&w=majority&appName=cluster1

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
LOGIN_RATE_LIMIT_MAX=100

# OpenRouter AI (free model)
OPENROUTER_API_KEY=your_openrouter_api_key

# Firebase Configuration (Public for Expo Frontend)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://your_local_ip:5000/api

EXPO_PUBLIC_OPENROUTER_API_KEY=your_expo_openrouter_api_key
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key
EXPO_PUBLIC_OCR_API_KEY=your_ocr_api_key

# Google OAuth Client ID (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# OpenWeatherMap API Key
EXPO_PUBLIC_WEATHER_API_KEY=your_openweathermap_api_key

