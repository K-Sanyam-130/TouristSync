{
  "expo": {
    "name": "TouristSync",
    "slug": "touristsync",
    "scheme": "touristsync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-video",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "touristGuide needs your microphone to capture speech for translation.",
          "speechRecognitionPermission": "tourist Guide uses speech recognition to translate what you say."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "tourist Guide uses speech recognition to translate what you say.",
        "NSMicrophoneUsageDescription": "touristGuide needs your microphone to capture speech for translation."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.kkrishr_06.madApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9b800c13-0bdd-41f3-ba3c-d333a45ef2bc"
      }
    }
  }
}
